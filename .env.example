# Environment Variables Setup Guide
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to Git - it's in .gitignore

# ==========================================
# Supabase Configuration (Database & Auth)
# ==========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==========================================
# API Configuration
# ==========================================
VITE_API_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:3000/api

# ==========================================
# Cloudinary Configuration (Image/Video Storage)
# ==========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ==========================================
# AI Service API Keys
# ==========================================
# RunwayML - Image to Video Generation
RUNWAY_API_KEY=your_runway_api_key_here

# ElevenLabs - Video Dubbing & Text-to-Speech
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Replicate - AI Model API
REPLICATE_API_TOKEN=your_replicate_token_here

# SyncLabs - Lip Syncing
SYNCLABS_API_KEY=your_synclabs_api_key_here

# ==========================================
# Node Environment
# ==========================================
NODE_ENV=development
